{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Echo Libero Trading Model v0.2",
  "description": "Schema for Polymarket portfolio/trading model with per-mandate accounting",
  "type": "object",
  "required": ["modelVersion", "asOf", "mandates", "allocations", "positions", "snapshots"],
  "properties": {
    "modelVersion": { "type": "string" },
    "asOf": { "type": "string", "format": "date-time" },
    "notes": { "type": "array", "items": { "type": "string" } },
    "mandates": {
      "type": "array",
      "description": "Obligation mandates from Anton. 1 token = 1 USD nominal.",
      "items": {
        "type": "object",
        "required": ["mandateId", "token", "nominalUsd", "strategyType"],
        "properties": {
          "mandateId": { "type": "string" },
          "token": { "type": "string", "enum": ["BANAL", "PMM", "MMXLM"] },
          "nominalUsd": { "type": "number", "description": "Face value of obligation in USD" },
          "strategyType": { "type": "string", "enum": ["BANAL", "PMM", "MMXLM"] },
          "description": { "type": "string" },
          "venue": { "type": "string" },
          "investor": { "type": "string" },
          "status": { "type": "string", "enum": ["active", "closed", "tracked-separately"] }
        }
      }
    },
    "allocations": {
      "type": "array",
      "description": "Per-mandate capital allocation breakdown",
      "items": {
        "type": "object",
        "required": ["mandateId", "nominalUsd"],
        "properties": {
          "mandateId": { "type": "string" },
          "freeCashUsd": { "type": ["number", "null"] },
          "openOrdersUsd": { "type": ["number", "null"] },
          "positionsCostUsd": { "type": ["number", "null"] },
          "positionsMarkUsd": { "type": ["number", "null"] },
          "unsettledUsd": { "type": ["number", "null"] },
          "equityUsd": { "type": ["number", "null"], "description": "free_cash + reserved + positions_mark" },
          "nominalUsd": { "type": "number" },
          "pnlUsd": { "type": ["number", "null"], "description": "equity - nominal" },
          "pnlPct": { "type": ["number", "null"] },
          "reconciliationStatus": { "type": "string", "enum": ["confirmed", "heuristic_split", "pending_market_split"] }
        }
      }
    },
    "positions": {
      "type": "array",
      "description": "Individual market positions with mark-to-market valuation",
      "items": {
        "type": "object",
        "required": ["positionId", "mandateId", "outcome", "strategyBucket", "netSize", "costBasis", "markPrice"],
        "properties": {
          "positionId": { "type": "string" },
          "mandateId": { "type": "string" },
          "marketConditionId": { "type": "string" },
          "outcome": { "type": "string", "description": "Polymarket outcome string (YES/NO/team name)" },
          "strategyBucket": { "type": "string", "enum": ["BANAL", "PMM"] },
          "side": { "type": "string", "enum": ["BUY", "SELL", "BID_ASK"] },
          "netSize": { "type": "number" },
          "costBasis": { "type": "number" },
          "avgEntry": { "type": "number", "description": "costBasis / netSize" },
          "markPrice": { "type": "number", "description": "Last trade price 0-1" },
          "markValue": { "type": "number", "description": "netSize * markPrice" },
          "unrealizedPnl": { "type": "number", "description": "markValue - costBasis" },
          "status": { "type": "string", "enum": ["WINNING", "LOSING", "SETTLED", "UNKNOWN"] },
          "notes": { "type": "string" }
        }
      }
    },
    "snapshots": {
      "type": "array",
      "description": "Historical equity snapshots — the time dimension of the model",
      "items": {
        "type": "object",
        "required": ["snapshotId", "asOf", "equityUsd", "depositNominalUsd"],
        "properties": {
          "snapshotId": { "type": "string" },
          "asOf": { "type": "string", "format": "date-time" },
          "freeCashUsd": { "type": "number" },
          "reservedOrdersUsd": { "type": "number" },
          "positionsCostUsd": { "type": "number" },
          "positionsMarkUsd": { "type": "number" },
          "equityUsd": { "type": "number" },
          "depositNominalUsd": { "type": "number" },
          "realizedPnlUsd": { "type": ["number", "null"] },
          "unrealizedPnlUsd": { "type": ["number", "null"] },
          "totalPnlUsd": { "type": "number" },
          "openOrdersCount": { "type": "integer" },
          "positionsCount": { "type": "integer" },
          "winningCount": { "type": "integer" },
          "losingCount": { "type": "integer" }
        }
      }
    },
    "portfolioSummary": {
      "type": "object",
      "description": "Aggregate portfolio view — confirmed numbers",
      "properties": {
        "asOf": { "type": "string" },
        "totalNominal": { "type": "number" },
        "totalEquity": { "type": "number" },
        "totalPnlUsd": { "type": "number" },
        "totalPnlPct": { "type": "number" },
        "freeCashUsd": { "type": "number" },
        "positionsCostUsd": { "type": "number" },
        "positionsMarkUsd": { "type": "number" },
        "openOrdersCount": { "type": "integer" },
        "positionsCount": { "type": "integer" },
        "winningCount": { "type": "integer" },
        "losingCount": { "type": "integer" }
      }
    },
    "redFlags": {
      "type": "array",
      "description": "Known model limitations and data gaps",
      "items": {
        "type": "object",
        "required": ["flagId", "severity", "message"],
        "properties": {
          "flagId": { "type": "string" },
          "severity": { "type": "string", "enum": ["warning", "error", "info"] },
          "scope": { "type": "string" },
          "message": { "type": "string" },
          "status": { "type": "string", "enum": ["open", "resolved"] }
        }
      }
    }
  }
}
